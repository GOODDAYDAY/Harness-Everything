{
  "//": "=== Pilot config for daily improvement loop ===",

  "feishu": {
    "app_id": "cli_YOUR_APP_ID",
    "app_secret": "YOUR_APP_SECRET",
    "chat_id": "oc_YOUR_CHAT_ID"
  },

  "schedule": {
    "hour": 9,
    "minute": 0
  },

  "llm": {
    "model": "vertex/claude-sonnet-4-6",
    "base_url": "http://127.0.0.1:9099",
    "max_tokens": 16384
  },

  "projects": [
    {
      "name": "ExampleProject",
      "workspace": "~/self/harness/ExampleProject",
      "tools": {
        "db_query": {
          "dsn": "postgresql://exampleuser:gdc@db-host:5432/exampleuser_test",
          "timeout": 30,
          "max_rows": 100
        }
      }
    }
  ],

  "diagnosis": {
    "max_cycles": 5
  },

  "execution": {
    "max_cycles": 50,
    "auto_commit": true,
    "auto_push": false,
    "push_remote": "origin",
    "push_branch": "feat/harness"
  },

  "proposal_expiry_hours": 24
}
