# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Temp files generated by harness runs
tmp*.json
tmp*.py

# Pipeline / agent configs contain sensitive paths, API keys, and project-specific prompts
pipeline_*.json
!config/pipeline_example_*.json
agent_*.json
!config/agent_example*.json

# Harness run output and metrics
harness_output*/
.harness_metrics.json
CHANGELOG_AUTO.md

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Virtual environment (must live outside workspace for security)
.venv/

# Runtime logs
logs/

# Backup files created by LLM
*.backup

# Test artifacts
test_*.py.bak

# Intelligence probe results — append-only runtime artifact, not source
benchmarks/evaluator_calibration/probe_results.jsonl
